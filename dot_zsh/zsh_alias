alias grep="grep --color=auto"

# Use nvim if it is available
if type nvim >/dev/null 2>&1; then
    alias vim="nvim"
fi

alias zookeeper='docker run --net=kafka --rm --name=zookeeper -e ZOOKEEPER_CLIENT_PORT=2181 confluentinc/cp-zookeeper:5.4.1'
alias kakfa='docker run --net=kafka --rm -p 9092:9092 --name=kafka -e KAFKA_ZOOKEEPER_CONNECT=zookeeper:2181 -e KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092 -e KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1 confluentinc/cp-kafka:5.4.1'
